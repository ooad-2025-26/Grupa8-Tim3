@page
@model RegisterModel

@{
    ViewData["Title"] = "Registracija";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Registracija</h1>
            <p>Kreiraj StudyBuddy nalog i pridruži se sesijama učenja.</p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email"
                       class="form-control"
                       id="emailInput"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3 password-field">
                <div class="form-floating">
                    <input asp-for="Input.Password"
                           class="form-control password-input"
                           id="passwordInput"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Npr. Studij1!" />
                    <label asp-for="Input.Password">Lozinka</label>
                </div>

                <button type="button" class="password-toggle" onclick="togglePassword(this)">
                    👁
                </button>

                <span asp-validation-for="Input.Password" class="text-danger"></span>
                <small id="passwordRulesMessage" class="password-help text-danger">
                    Lozinka treba imati najmanje 7 karaktera, jedno veliko slovo, jedan broj i jedan specijalni znak.
                </small>
            </div>

            <div class="mb-3 password-field">
                <div class="form-floating">
                    <input asp-for="Input.ConfirmPassword"
                           class="form-control password-input"
                           id="confirmPasswordInput"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Potvrdi lozinku" />
                    <label asp-for="Input.ConfirmPassword">Potvrdi lozinku</label>
                </div>

                <button type="button" class="password-toggle" onclick="togglePassword(this)">
                    👁
                </button>

                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                <span id="passwordMatchMessage" class="password-match-message text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="w-100 btn btn-primary-sb" disabled>
                Registruj se
            </button>

            <div class="auth-links mt-3">
                <p>
                    Već imaš nalog?
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Prijavi se</a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(button) {
            const wrapper = button.closest(".password-field");
            const input = wrapper.querySelector(".password-input");

            if (input.type === "password") {
                input.type = "text";
                button.textContent = "🙈";
            } else {
                input.type = "password";
                button.textContent = "👁";
            }
        }

        const emailInput = document.getElementById("emailInput");
        const passwordInput = document.getElementById("passwordInput");
        const confirmPasswordInput = document.getElementById("confirmPasswordInput");
        const passwordRulesMessage = document.getElementById("passwordRulesMessage");
        const passwordMatchMessage = document.getElementById("passwordMatchMessage");
        const registerSubmit = document.getElementById("registerSubmit");

        function lozinkaIspunjavaPravila(lozinka) {
            const imaMinimalnuDuzinu = lozinka.length >= 7;
            const imaVelikoSlovo = /[A-Z]/.test(lozinka);
            const imaBroj = /[0-9]/.test(lozinka);
            const imaSpecijalniZnak = /[^A-Za-z0-9]/.test(lozinka);

            return imaMinimalnuDuzinu && imaVelikoSlovo && imaBroj && imaSpecijalniZnak;
        }

        function emailJeValidan(email) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
        }

        function provjeriFormu() {
            const email = emailInput.value.trim();
            const lozinka = passwordInput.value;
            const potvrda = confirmPasswordInput.value;

            const emailOk = emailJeValidan(email);
            const lozinkaOk = lozinkaIspunjavaPravila(lozinka);
            const potvrdaUnesena = potvrda.length > 0;
            const lozinkeIste = lozinka === potvrda;

            passwordInput.classList.remove("is-invalid");
            confirmPasswordInput.classList.remove("is-invalid");

            if (lozinka.length === 0) {
                passwordRulesMessage.textContent = "";
                passwordRulesMessage.classList.remove("text-success", "text-danger");
            } else if (!lozinkaOk) {
                passwordRulesMessage.textContent = "Lozinka treba imati najmanje 7 karaktera, jedno veliko slovo, jedan broj i jedan specijalni znak.";
                passwordRulesMessage.classList.remove("text-success");
                passwordRulesMessage.classList.add("text-danger");
                passwordInput.classList.add("is-invalid");
            } else {
                passwordRulesMessage.textContent = "Lozinka ispunjava uslove.";
                passwordRulesMessage.classList.remove("text-danger");
                passwordRulesMessage.classList.add("text-success");
            }

            if (!potvrdaUnesena) {
                passwordMatchMessage.textContent = "";
            } else if (!lozinkeIste) {
                passwordMatchMessage.textContent = "Lozinke se ne poklapaju.";
                confirmPasswordInput.classList.add("is-invalid");
            } else {
                passwordMatchMessage.textContent = "";
            }

            registerSubmit.disabled = !(emailOk && lozinkaOk && potvrdaUnesena && lozinkeIste);
        }

        emailInput.addEventListener("input", provjeriFormu);
        passwordInput.addEventListener("input", provjeriFormu);
        confirmPasswordInput.addEventListener("input", provjeriFormu);

        provjeriFormu();
    </script>
}