@page
@model AccessDeniedModel

@{
    ViewData["Title"] = "Pristup odbijen";
}

<div class="auth-page">
    <div class="auth-card access-card">
        <div class="auth-header">
            <div class="access-icon">!</div>
            <h1>Pristup odbijen</h1>
            <p>
                Nemaš dozvolu za pristup ovoj stranici.
            </p>
        </div>

        <div class="access-actions">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary-sb">
                Početna
            </a>

            <a asp-area="" asp-controller="SesijaUcenja" asp-action="Index" class="btn btn-outline-sb">
                Nazad na sesije
            </a>
        </div>
    </div>
</div>