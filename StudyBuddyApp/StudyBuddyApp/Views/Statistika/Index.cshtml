@model IEnumerable<StudyBuddyApp.Services.Statistics.StatistikaRezultat>
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Statistika";
    var prikazaniKorisnik = ViewBag.PrikazaniKorisnik as Korisnik;
}

<div class="page-header">
    <div class="page-title-row centered">
        <a asp-controller="Home"
               asp-action="Index"
               class="icon-back-btn"
               title="Nazad na početnu"
               aria-label="Nazad na početnu">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <h1>Statistika učenja</h1>
            <p>
                Pregled osnovnih pokazatelja aktivnosti za korisnika:
                <strong>@ViewBag.KorisnikIme</strong>
            </p>
        </div>
    </div>
</div>

@if (TempData["Greska"] != null)
{
    <div class="alert alert-danger">
        @TempData["Greska"]
    </div>
}

@if (User.IsInRole("Administrator"))
{
    <div class="form-card statistics-filter-card">
        <form asp-action="Index" method="get">
            <div class="form-grid">
                <div class="form-group form-full">
                    <label class="control-label">Odaberi korisnika</label>
                    <select name="korisnikId" class="form-select" asp-items="ViewBag.Korisnici" onchange="this.form.submit()">
                        <option value="">-- Odaberite korisnika --</option>
                    </select>
                </div>
            </div>
        </form>
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Nema statistike</h3>
        <p>Trenutno nema dovoljno podataka za prikaz statistike.</p>
    </div>
}
else
{
    <div class="stats-grid">
        @foreach (var item in Model)
        {
            var naziv = item.Naziv?.ToLower() ?? "";
            var ikonica = "📊";

            if (naziv.Contains("vrijeme") || naziv.Contains("učenja") || naziv.Contains("ucenja"))
            {
                ikonica = "⏳";
            }
            else if (naziv.Contains("prisust"))
            {
                ikonica = "✅";
            }
            else if (naziv.Contains("sesij"))
            {
                ikonica = "📚";
            }

            <div class="stats-card stats-card-with-icon">
                <div class="stats-icon">@ikonica</div>

                <div class="stats-content">
                    <span class="stats-label">@item.Naziv</span>
                    <strong>@item.Vrijednost</strong>
                    <p>@item.Opis</p>
                </div>
            </div>
        }
    </div>
}