@model StudyBuddyApp.Models.Prisustvo

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Prisustvo</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdPrisustva" />
            <div class="form-group">
                <label asp-for="KorisnikId" class="control-label"></label>
                <select asp-for="KorisnikId" class="form-control" asp-items="ViewBag.KorisnikId"></select>
                <span asp-validation-for="KorisnikId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SesijaId" class="control-label"></label>
                <select asp-for="SesijaId" class="form-control" asp-items="ViewBag.SesijaId"></select>
                <span asp-validation-for="SesijaId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TrajanjeUcenja" class="control-label"></label>
                <input asp-for="TrajanjeUcenja" class="form-control" />
                <span asp-validation-for="TrajanjeUcenja" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StatusPrisustva" class="control-label"></label>
                <select asp-for="StatusPrisustva" class="form-control"></select>
                <span asp-validation-for="StatusPrisustva" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
