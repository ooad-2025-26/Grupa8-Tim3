@model IEnumerable<StudyBuddyApp.Models.Prisustvo>

@{
    ViewData["Title"] = "Prisustva";
}

<h1>Prisustva</h1>

@if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Korisnik)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SesijaUcenja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TrajanjeUcenja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StatusPrisustva)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Korisnik!.Ime)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SesijaUcenja!.Naziv)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TrajanjeUcenja)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.StatusPrisustva)
                </td>
                <td>
                    @if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.IdPrisustva">Edit</a>
                        <span>|</span>
                    }

                    <a asp-action="Details" asp-route-id="@item.IdPrisustva">Details</a>

                    @if (User.IsInRole("Administrator"))
                    {
                        <span>|</span>
                        <a asp-action="Delete" asp-route-id="@item.IdPrisustva">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>