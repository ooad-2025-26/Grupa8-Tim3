@model IEnumerable<StudyBuddyApp.Models.Prisustvo>

@{
    ViewData["Title"] = "Prisustva";
}

<div class="page-header">
    <div>
        <h1>Prisustva</h1>
        <p>Pregled evidentiranog prisustva i trajanja učenja na sesijama.</p>
    </div>

    @if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
    {
        <a asp-action="Create" class="btn btn-primary-sb">Evidentiraj prisustvo</a>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Nema evidentiranog prisustva</h3>
        <p>Trenutno nema zapisa o prisustvu na sesijama.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Korisnik</th>
                    <th>Sesija</th>
                    <th>Trajanje učenja</th>
                    <th>Status</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.StatusPrisustva.ToString() == "Prisutan" ? "status-active" : "status-muted";

                    <tr>
                        <td>@item.Korisnik?.Ime</td>
                        <td>@item.SesijaUcenja?.Naziv</td>
                        <td>@item.TrajanjeUcenja min</td>
                        <td>
                            <span class="session-status @statusClass">
                                @item.StatusPrisustva
                            </span>
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.IdPrisustva" class="btn btn-outline-sb btn-sm">
                                    Detalji
                                </a>

                                @if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IdPrisustva" class="btn btn-secondary btn-sm">
                                        Uredi
                                    </a>
                                }

                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.IdPrisustva" class="btn btn-danger btn-sm">
                                        Obriši
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}