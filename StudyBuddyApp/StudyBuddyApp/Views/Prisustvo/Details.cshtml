@model StudyBuddyApp.Models.Prisustvo

@{
    ViewData["Title"] = "Detalji prisustva";
    var statusClass = Model.StatusPrisustva.ToString() == "Prisutan" ? "status-active" : "status-muted";
    var korisnikIme = Model.Korisnik != null
        ? $"{Model.Korisnik.Ime} {Model.Korisnik.Prezime}"
        : "Nepoznat korisnik";
    var nazivSesije = Model.SesijaUcenja?.Naziv ?? "Nepoznata sesija";
}

<div class="page-header">
    <div>
        <h1>Detalji prisustva</h1>
        <p>Pregled evidentiranog prisustva za odabranu sesiju učenja.</p>
    </div>
</div>

<div class="details-card">
    <div class="session-card-top">
        <span class="session-subject">@nazivSesije</span>
        <span class="session-status @statusClass">@Model.StatusPrisustva</span>
    </div>

    <h2>@korisnikIme</h2>

    <div class="details-info">
        <div>
            <span>Korisnik</span>
            <strong>@korisnikIme</strong>
        </div>

        <div>
            <span>Email</span>
            <strong>@(Model.Korisnik?.Email ?? "Nije dostupan")</strong>
        </div>

        <div>
            <span>Sesija učenja</span>
            <strong>@nazivSesije</strong>
        </div>

        <div>
            <span>Trajanje učenja</span>
            <strong>@Model.TrajanjeUcenja min</strong>
        </div>

        <div>
            <span>Status prisustva</span>
            <strong>@Model.StatusPrisustva</strong>
        </div>
    </div>

    <div class="details-actions">
        @if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
        {
            <a asp-action="Edit" asp-route-id="@Model.IdPrisustva" class="btn btn-secondary">
                Uredi
            </a>

            <a asp-action="Delete" asp-route-id="@Model.IdPrisustva" class="btn btn-danger">
                Obriši
            </a>
        }

        <a asp-action="Index" class="btn btn-outline-sb">
            Nazad na prisustva
        </a>
    </div>
</div>