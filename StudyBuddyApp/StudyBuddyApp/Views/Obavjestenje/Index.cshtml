@model IEnumerable<StudyBuddyApp.Models.Obavjestenje>

@{
    ViewData["Title"] = "Obavještenja";
}

<div class="page-header">
    <div class="page-title-row">
        <a asp-controller="Home"
               asp-action="Index"
               class="icon-back-btn"
               title="Nazad na početnu"
               aria-label="Nazad na početnu">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <h1>Obavještenja</h1>
            <p>Pregledaj najnovije informacije o prijavama i sesijama.</p>
        </div>
    </div>
</div>

@if (TempData["Poruka"] != null)
{
    <div class="alert alert-success">
        @TempData["Poruka"]
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Nema obavještenja</h3>
        <p>Trenutno nema dostupnih obavještenja za prikaz.</p>
    </div>
}
else
{
    <div class="notification-list">
        @foreach (var item in Model)
        {
            var procitanoClass = item.Procitano ? "notification-read" : "notification-unread";
            var procitanoText = item.Procitano ? "Pročitano" : "Nepročitano";
            var datum = item.DatumSlanja.ToLocalTime().ToString("dd.MM.yyyy. HH:mm");
            var sadrzaj = item.Sadrzaj?.Length > 160 ? item.Sadrzaj.Substring(0, 160) + "..." : item.Sadrzaj;

            <div class="notification-card @procitanoClass">
                <div class="notification-main">
                    <div class="notification-header">
                        <div>
                            <span class="notification-type">@item.TipObavjestenja</span>
                            <h2>@item.Naslov</h2>
                        </div>

                        <span class="notification-status">
                            @procitanoText
                        </span>
                    </div>

                    <p class="notification-content">@sadrzaj</p>

                    <div class="notification-meta">
                        <span>Korisnik: <strong>@item.Korisnik?.Ime</strong></span>
                        <span>Datum: <strong>@datum</strong></span>
                    </div>
                </div>

                <div class="notification-actions">
                    <a asp-action="Details" asp-route-id="@item.IdObavjestenja" class="btn btn-outline-sb btn-action-equal">
                        Detalji
                    </a>

                    @if (!item.Procitano)
                    {
                        <form asp-action="OznaciKaoProcitano" asp-route-id="@item.IdObavjestenja" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-soft-gray btn-action-equal">
                                Označi kao pročitano
                            </button>
                        </form>
                    }

                    @if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.IdObavjestenja" class="btn btn-secondary">
                            Uredi
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.IdObavjestenja" class="btn btn-danger">
                            Obriši
                        </a>
                    }
                </div>
            </div>
        }
    </div>
}