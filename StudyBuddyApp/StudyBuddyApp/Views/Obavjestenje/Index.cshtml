@model IEnumerable<StudyBuddyApp.Models.Obavjestenje>

@{
    ViewData["Title"] = "Obavještenja";
}

<h1>Obavještenja</h1>

@if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Naslov)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Sadrzaj)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumSlanja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Korisnik)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TipObavjestenja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Procitano)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Naslov)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Sadrzaj)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DatumSlanja)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Korisnik!.Ime)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TipObavjestenja)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Procitano)
                </td>
                <td>
                    @if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.IdObavjestenja">Edit</a>
                        <span>|</span>
                    }

                    <a asp-action="Details" asp-route-id="@item.IdObavjestenja">Details</a>

                    @if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
                    {
                        <span>|</span>
                        <a asp-action="Delete" asp-route-id="@item.IdObavjestenja">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>