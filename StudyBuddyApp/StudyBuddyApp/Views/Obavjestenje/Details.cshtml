@model StudyBuddyApp.Models.Obavjestenje

@{
    ViewData["Title"] = "Detalji obavještenja";

    var datum = Model.DatumSlanja.ToLocalTime().ToString("dd.MM.yyyy. HH:mm");
    var korisnikNaziv = Model.Korisnik != null
        ? $"{Model.Korisnik.Ime} {Model.Korisnik.Prezime} ({Model.Korisnik.Email})"
        : "Nepoznat korisnik";
}

<div class="page-header">
    <div class="page-title-row">
        <a asp-controller="Home"
               asp-action="Index"
               class="icon-back-btn"
               title="Nazad na početnu"
               aria-label="Nazad na početnu">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <h1>Detalji obavještenja</h1>
        </div>
    </div>
</div>

<div class="details-card notification-details-card">
    <div class="details-top">
        <div>
            <span class="notification-type">@Model.TipObavjestenja</span>
            <h2>@Model.Naslov</h2>
        </div>

        @if (Model.Procitano)
        {
            <span class="notification-status">Pročitano</span>
        }
        else
        {
            <span class="notification-status">Nepročitano</span>
        }
    </div>

    <div class="details-description">
        <h3>Sadržaj</h3>
        <p>@Model.Sadrzaj</p>
    </div>

    <div class="details-info">
        <div>
            <span>Datum slanja</span>
            <strong>@datum</strong>
        </div>

        <div>
            <span>Korisnik</span>
            <strong>@korisnikNaziv</strong>
        </div>
    </div>

    <div class="details-actions">
        @if (!Model.Procitano)
        {
            <form asp-action="OznaciKaoProcitano" asp-route-id="@Model.IdObavjestenja" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary-sb">Označi kao pročitano</button>
            </form>
        }

        @if (User.IsInRole("Administrator") || User.IsInRole("Moderator"))
        {
            <a asp-action="Edit" asp-route-id="@Model.IdObavjestenja" class="btn btn-secondary">
                Uredi
            </a>
        }

        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteNotificationModal">
            Obriši obavještenje
        </button>

        <a asp-action="Index" class="btn btn-outline-sb btn-action-equal">
            Nazad na obavještenja
        </a>
    </div>
</div>

<div class="modal fade" id="deleteNotificationModal" tabindex="-1" aria-labelledby="deleteNotificationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content sb-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteNotificationModalLabel">Brisanje obavještenja</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zatvori"></button>
            </div>

            <div class="modal-body">
                Da li ste sigurni da želite obrisati ovo obavještenje?
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-sb" data-bs-dismiss="modal">Odustani</button>

                <form asp-action="DeleteFromDetails" asp-route-id="@Model.IdObavjestenja" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Obriši</button>
                </form>
            </div>
        </div>
    </div>
</div>