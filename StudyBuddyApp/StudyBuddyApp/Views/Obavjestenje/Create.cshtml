@model StudyBuddyApp.Models.Obavjestenje
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Kreiranje obavještenja";
}

<div class="page-header">
    <div>
        <h1>Kreiranje obavještenja</h1>
        <p>Pošalji obavještenje odabranom korisniku sistema.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-grid">
            <div class="form-group form-full">
                <label asp-for="Naslov" class="control-label">Naslov</label>
                <input asp-for="Naslov" class="form-control" placeholder="Npr. Promjena termina sesije" />
                <span asp-validation-for="Naslov" class="text-danger"></span>
            </div>

            <div class="form-group form-full">
                <label asp-for="Sadrzaj" class="control-label">Sadržaj</label>
                <textarea asp-for="Sadrzaj" class="form-control" rows="4" placeholder="Unesi tekst obavještenja."></textarea>
                <span asp-validation-for="Sadrzaj" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DatumSlanja" class="control-label">Datum slanja</label>
                <input asp-for="DatumSlanja" class="form-control" type="datetime-local" />
                <span asp-validation-for="DatumSlanja" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="KorisnikId" class="control-label">Korisnik</label>
                <select asp-for="KorisnikId" class="form-select" asp-items="ViewBag.KorisnikId">
                    <option value="">-- Odaberite korisnika --</option>
                </select>
                <span asp-validation-for="KorisnikId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TipObavjestenja" class="control-label">Tip obavještenja</label>
                <select asp-for="TipObavjestenja" class="form-select" asp-items="Html.GetEnumSelectList<TipObavjestenja>()"></select>
                <span asp-validation-for="TipObavjestenja" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Status</label>
                <div class="form-check pretty-check">
                    <input class="form-check-input" asp-for="Procitano" />
                    <label class="form-check-label" asp-for="Procitano">
                        Označi kao pročitano
                    </label>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary-sb">Sačuvaj</button>
            <a asp-action="Index" class="btn btn-outline-sb">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}