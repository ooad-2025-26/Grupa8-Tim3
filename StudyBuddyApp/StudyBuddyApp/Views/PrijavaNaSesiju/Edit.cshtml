@model StudyBuddyApp.Models.PrijavaNaSesiju
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Uređivanje prijave";
}

<div class="page-header">
    <div>
        <h1>Uređivanje prijave</h1>
        <p>Izmijeni podatke o prijavi korisnika na sesiju učenja.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <input type="hidden" asp-for="IdPrijave" />

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="DatumPrijave" class="control-label">Datum prijave</label>
                <input asp-for="DatumPrijave" class="form-control" type="datetime-local" />
                <span asp-validation-for="DatumPrijave" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="KorisnikId" class="control-label">Korisnik</label>
                <select asp-for="KorisnikId" class="form-select" asp-items="ViewBag.KorisnikId">
                    <option value="">-- Odaberite korisnika --</option>
                </select>
                <span asp-validation-for="KorisnikId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SesijaId" class="control-label">Sesija</label>
                <select asp-for="SesijaId" class="form-select" asp-items="ViewBag.SesijaId">
                    <option value="">-- Odaberite sesiju --</option>
                </select>
                <span asp-validation-for="SesijaId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StatusPrijave" class="control-label">Status prijave</label>
                <select asp-for="StatusPrijave" class="form-select" asp-items="Html.GetEnumSelectList<StatusPrijave>()"></select>
                <span asp-validation-for="StatusPrijave" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary-sb">Sačuvaj</button>
            <a asp-action="Index" class="btn btn-outline-sb">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}