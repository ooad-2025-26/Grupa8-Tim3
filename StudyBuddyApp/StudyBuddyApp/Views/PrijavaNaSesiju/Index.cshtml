@model IEnumerable<StudyBuddyApp.Models.PrijavaNaSesiju>

@{
    ViewData["Title"] = "Prijave na sesiju";
}

<div class="page-header">
    <div class="page-title-row">
        <a asp-controller="Home"
               asp-action="Index"
               class="icon-back-btn"
               title="Nazad na početnu"
               aria-label="Nazad na početnu">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <h1>Prijave na sesije</h1>
            <p>Pregled prijava na sesije učenja.</p>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Nema prijava</h3>
        <p>Trenutno nema evidentiranih prijava na sesije.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Datum prijave</th>
                    <th>Korisnik</th>
                    <th>Sesija</th>
                    <th>Status</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var datum = item.DatumPrijave.ToLocalTime().ToString("dd.MM.yyyy. HH:mm");
                    var statusClass = item.StatusPrijave.ToString() == "Prijavljen" ? "status-active" : "status-muted";

                    <tr>
                        <td>@datum</td>
                        <td>@item.Korisnik?.Ime</td>
                        <td>@item.SesijaUcenja?.Naziv</td>
                        <td>
                            <span class="session-status @statusClass">
                                @item.StatusPrijave
                            </span>
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.IdPrijave" class="btn btn-outline-sb btn-sm">
                                    Detalji
                                </a>

                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IdPrijave" class="btn btn-secondary btn-sm">
                                        Uredi
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.IdPrijave" class="btn btn-danger btn-sm">
                                        Obriši
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}