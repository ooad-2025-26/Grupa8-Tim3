@model IEnumerable<StudyBuddyApp.Models.PrijavaNaSesiju>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DatumPrijave)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Korisnik)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SesijaUcenja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StatusPrijave)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DatumPrijave)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Korisnik.IdKorisnika)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SesijaUcenja.IdSesije)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StatusPrijave)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdPrijave">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.IdPrijave">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.IdPrijave">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
