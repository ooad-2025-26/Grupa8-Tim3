@model StudyBuddyApp.Models.SesijaUcenja
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Uredi status sesije";
}

<div class="form-page">

    <div class="page-title-row">
        <a asp-action="Details"
               asp-route-id="@Model.IdSesije"
               class="icon-back-btn"
               title="Nazad na detalje sesije"
               aria-label="Nazad na detalje sesije">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <h1>Uredi status sesije</h1>
            <p>Promijeni samo status odabrane sesije.</p>
        </div>
    </div>

    <div class="form-card">
        <form asp-action="EditStatus" asp-route-id="@Model.IdSesije" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="IdSesije" />

            <div class="form-group mb-3">
                <label class="control-label">Sesija</label>
                <input class="form-control" value="@Model.Naziv" disabled />
            </div>

            <div class="form-group mb-4">
                <label asp-for="StatusSesije" class="control-label">Status sesije</label>
                <select asp-for="StatusSesije"
                        class="form-select"
                        asp-items="Html.GetEnumSelectList<StatusSesije>()">
                </select>
                <span asp-validation-for="StatusSesije" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary-sb btn-action-equal">
                    Sačuvaj status
                </button>

                <a asp-action="Details"
                       asp-route-id="@Model.IdSesije"
                       class="btn btn-outline-sb btn-action-equal">
                    Odustani
                </a>
            </div>
        </form>
    </div>
</div>