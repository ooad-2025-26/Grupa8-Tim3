@model StudyBuddyApp.Models.SesijaUcenja
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Kreiranje sesije";
}

<div class="page-header">
    <div>
        <h1>Kreiranje sesije</h1>
        <p>Popuni osnovne informacije i organizuj novu sesiju učenja.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-grid">
            <div class="form-group form-full">
                <label asp-for="Naziv" class="control-label">Naziv sesije</label>
                <input asp-for="Naziv" class="form-control" placeholder="Npr. OOAD priprema za ispit" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>

            <div class="form-group form-full">
                <label asp-for="Opis" class="control-label">Opis</label>
                <textarea asp-for="Opis" class="form-control" rows="4" placeholder="Ukratko opiši šta će se raditi na sesiji."></textarea>
                <span asp-validation-for="Opis" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DatumVrijeme" class="control-label">Datum i vrijeme</label>
                <input asp-for="DatumVrijeme" class="form-control" type="datetime-local" />
                <span asp-validation-for="DatumVrijeme" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Trajanje" class="control-label">Trajanje u minutama</label>
                <input asp-for="Trajanje" class="form-control" type="number" min="1" placeholder="Npr. 90" />
                <span asp-validation-for="Trajanje" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Godina studija</label>
                <select id="godinaStudijaFilter" class="form-select">
                    <option value="">Odaberi godinu</option>
                    @foreach (GodinaStudija godina in Enum.GetValues(typeof(GodinaStudija)))
                    {
                        <option value="@godina">@godina</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="control-label">Smjer studija</label>
                <select id="smjerStudijaFilter" class="form-select">
                    <option value="">Odaberi smjer</option>
                    @foreach (SmjerStudija smjer in Enum.GetValues(typeof(SmjerStudija)))
                    {
                        <option value="@smjer">@smjer</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label asp-for="PredmetId" class="control-label">Predmet</label>
                <select asp-for="PredmetId" class="form-select" id="predmetSelect">
                    <option value="">Prvo odaberi godinu i smjer</option>
                </select>
                <span asp-validation-for="PredmetId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LokacijaId" class="control-label">Lokacija</label>
                <select asp-for="LokacijaId" class="form-select" asp-items="ViewBag.LokacijaId" id="lokacijaSelect">
                    <option value="">-- Odaberite lokaciju --</option>
                    <option value="-1">Dodaj novu lokaciju</option>
                </select>
                <span asp-validation-for="LokacijaId" class="text-danger"></span>
            </div>

            <div id="novaLokacijaPolja" class="form-group form-full" style="display: none;">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="control-label">Naziv nove lokacije</label>
                        <input name="NovaLokacijaNaziv" class="form-control" placeholder="Npr. Moja čitaonica" />
                    </div>

                    <div class="form-group">
                        <label class="control-label">Tip lokacije</label>
                        <select name="NovaLokacijaTip" class="form-select" id="novaLokacijaTip">
                            <option value="">Odaberi tip lokacije</option>
                            @foreach (TipLokacije tip in Enum.GetValues(typeof(TipLokacije)))
                            {
                                <option value="@tip">@tip</option>
                            }
                        </select>
                    </div>

                    <div class="form-group" id="novaAdresaPolje">
                        <label class="control-label">Adresa</label>
                        <input name="NovaLokacijaAdresa" class="form-control" placeholder="Npr. Zmaja od Bosne bb, Sarajevo" />
                    </div>

                    <div class="form-group" id="novaLinkPolje">
                        <label class="control-label">Link</label>
                        <input name="NovaLokacijaLink" class="form-control" placeholder="Npr. https://meet.google.com/new" />
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="MaksimalanBrojUcesnika" class="control-label">Kapacitet</label>
                <input asp-for="MaksimalanBrojUcesnika" class="form-control" type="number" min="1" placeholder="Npr. 5" />
                <span asp-validation-for="MaksimalanBrojUcesnika" class="text-danger"></span>
            </div>

        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary-sb btn-action-equal">Sačuvaj</button>
            <a asp-action="Index" class="btn btn-outline-sb btn-action-equal">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const godinaSelect = document.getElementById("godinaStudijaFilter");
        const smjerSelect = document.getElementById("smjerStudijaFilter");
        const predmetSelect = document.getElementById("predmetSelect");

        async function ucitajPredmete() {
            const godina = godinaSelect.value;
            const smjer = smjerSelect.value;

            predmetSelect.innerHTML = "";

            if (!godina || !smjer) {
                predmetSelect.innerHTML = '<option value="">Prvo odaberi godinu i smjer</option>';
                return;
            }

            const response = await fetch(`/SesijaUcenja/GetPredmetiByGodinaISmjer?godinaStudija=${godina}&smjerStudija=${smjer}`);
            const predmeti = await response.json();

            if (predmeti.length === 0) {
                predmetSelect.innerHTML = '<option value="">Nema predmeta za odabranu godinu i smjer</option>';
                return;
            }

            predmetSelect.innerHTML = '<option value="">Odaberi predmet</option>';

            predmeti.forEach(predmet => {
                const option = document.createElement("option");
                option.value = predmet.id;
                option.textContent = predmet.naziv;
                predmetSelect.appendChild(option);
            });
        }

        godinaSelect.addEventListener("change", ucitajPredmete);
        smjerSelect.addEventListener("change", ucitajPredmete);

        const lokacijaSelect = document.getElementById("lokacijaSelect");
        const novaLokacijaPolja = document.getElementById("novaLokacijaPolja");
        const novaLokacijaTip = document.getElementById("novaLokacijaTip");
        const novaAdresaPolje = document.getElementById("novaAdresaPolje");
        const novaLinkPolje = document.getElementById("novaLinkPolje");

        function prikaziPoljaZaNovuLokaciju() {
            if (lokacijaSelect.value === "-1") {
                novaLokacijaPolja.style.display = "block";
            } else {
                novaLokacijaPolja.style.display = "none";
            }
        }

        function prilagodiPoljaPoTipuLokacije() {
            const tip = novaLokacijaTip.value;

            if (tip === "Online") {
                novaAdresaPolje.style.display = "none";
                novaLinkPolje.style.display = "block";
            } else if (tip === "Fizicka") {
                novaAdresaPolje.style.display = "block";
                novaLinkPolje.style.display = "none";
            } else {
                novaAdresaPolje.style.display = "block";
                novaLinkPolje.style.display = "block";
            }
        }

        lokacijaSelect.addEventListener("change", prikaziPoljaZaNovuLokaciju);
        novaLokacijaTip.addEventListener("change", prilagodiPoljaPoTipuLokacije);

        prikaziPoljaZaNovuLokaciju();
        prilagodiPoljaPoTipuLokacije();
    </script>
}