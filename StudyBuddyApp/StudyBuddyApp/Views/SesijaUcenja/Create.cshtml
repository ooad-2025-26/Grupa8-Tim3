@model StudyBuddyApp.Models.SesijaUcenja
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Kreiranje sesije";
}

<h1>Kreiranje sesije</h1>

<h4>Sesija učenja</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Naziv" class="control-label"></label>
                <input asp-for="Naziv" class="form-control" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Opis" class="control-label"></label>
                <textarea asp-for="Opis" class="form-control"></textarea>
                <span asp-validation-for="Opis" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DatumVrijeme" class="control-label"></label>
                <input asp-for="DatumVrijeme" class="form-control" type="datetime-local" />
                <span asp-validation-for="DatumVrijeme" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Trajanje" class="control-label"></label>
                <input asp-for="Trajanje" class="form-control" />
                <span asp-validation-for="Trajanje" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LokacijaId" class="control-label">Lokacija</label>
                <select asp-for="LokacijaId" class="form-control" asp-items="ViewBag.LokacijaId">
                    <option value="">-- Odaberite lokaciju --</option>
                </select>
                <span asp-validation-for="LokacijaId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PredmetId" class="control-label">Predmet</label>
                <select asp-for="PredmetId" class="form-control" asp-items="ViewBag.PredmetId">
                    <option value="">-- Odaberite predmet --</option>
                </select>
                <span asp-validation-for="PredmetId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaksimalanBrojUcesnika" class="control-label"></label>
                <input asp-for="MaksimalanBrojUcesnika" class="form-control" />
                <span asp-validation-for="MaksimalanBrojUcesnika" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StatusSesije" class="control-label"></label>
                <select asp-for="StatusSesije" class="form-control" asp-items="Html.GetEnumSelectList<StatusSesije>()"></select>
                <span asp-validation-for="StatusSesije" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}