@model StudyBuddyApp.Models.SesijaUcenja
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Kreiranje sesije";
}

<div class="page-header">
    <div>
        <h1>Kreiranje sesije</h1>
        <p>Popuni osnovne informacije i organizuj novu sesiju učenja.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-grid">
            <div class="form-group form-full">
                <label asp-for="Naziv" class="control-label">Naziv sesije</label>
                <input asp-for="Naziv" class="form-control" placeholder="Npr. OOAD priprema" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>

            <div class="form-group form-full">
                <label asp-for="Opis" class="control-label">Opis</label>
                <textarea asp-for="Opis" class="form-control" rows="4" placeholder="Ukratko opiši šta će se raditi na sesiji."></textarea>
                <span asp-validation-for="Opis" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DatumVrijeme" class="control-label">Datum i vrijeme</label>
                <input asp-for="DatumVrijeme" class="form-control" type="datetime-local" />
                <span asp-validation-for="DatumVrijeme" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Trajanje" class="control-label">Trajanje u minutama</label>
                <input asp-for="Trajanje" class="form-control" type="number" min="1" placeholder="Npr. 90" />
                <span asp-validation-for="Trajanje" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PredmetId" class="control-label">Predmet</label>
                <select asp-for="PredmetId" class="form-select" asp-items="ViewBag.PredmetId">
                    <option value="">-- Odaberite predmet --</option>
                </select>
                <span asp-validation-for="PredmetId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LokacijaId" class="control-label">Lokacija</label>
                <select asp-for="LokacijaId" class="form-select" asp-items="ViewBag.LokacijaId">
                    <option value="">-- Odaberite lokaciju --</option>
                </select>
                <span asp-validation-for="LokacijaId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaksimalanBrojUcesnika" class="control-label">Kapacitet</label>
                <input asp-for="MaksimalanBrojUcesnika" class="form-control" type="number" min="1" placeholder="Npr. 5" />
                <span asp-validation-for="MaksimalanBrojUcesnika" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StatusSesije" class="control-label">Status sesije</label>
                <select asp-for="StatusSesije" class="form-select" asp-items="Html.GetEnumSelectList<StatusSesije>()"></select>
                <span asp-validation-for="StatusSesije" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary-sb">Sačuvaj</button>
            <a asp-action="Index" class="btn btn-outline-sb">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}