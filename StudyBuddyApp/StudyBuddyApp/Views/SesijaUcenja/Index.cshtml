@model IEnumerable<StudyBuddyApp.Models.SesijaUcenja>
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Sesije učenja";
    bool samoSlobodnaMjesta = ViewBag.SamoSlobodnaMjesta == true;
}

<div class="page-header">
    <div>
        <h1>Pregled sesija</h1>
        <p>Pronađi dostupne sesije učenja i pridruži se aktivnim terminima.</p>
    </div>

    @if (User.IsInRole("Administrator") || User.IsInRole("Student"))
    {
        <a asp-action="Create" class="btn btn-primary-sb">Kreiraj sesiju</a>
    }
</div>

@if (TempData["Poruka"] != null)
{
    <div class="alert alert-success">
        @TempData["Poruka"]
    </div>
}

<div class="session-filter-card">
    <form asp-controller="SesijaUcenja" asp-action="Index" method="get">
        <div class="session-filter-grid">
            <div class="form-group filter-search">
                <label class="control-label">Pretraga</label>
                <input type="text"
                       name="pretraga"
                       value="@ViewBag.Pretraga"
                       class="form-control"
                       placeholder="Pretraži naziv, opis, predmet ili lokaciju..." />
            </div>

            <div class="form-group">
                <label class="control-label">Godina studija</label>
                <select name="godinaStudija" class="form-select">
                    <option value="">Sve godine</option>
                    @foreach (GodinaStudija godina in Enum.GetValues(typeof(GodinaStudija)))
                    {
                        if (ViewBag.GodinaStudija == godina.ToString())
                        {
                            <option value="@godina" selected>@godina</option>
                        }
                        else
                        {
                            <option value="@godina">@godina</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="control-label">Smjer studija</label>
                <select name="smjerStudija" class="form-select">
                    <option value="">Svi smjerovi</option>
                    @foreach (SmjerStudija smjer in Enum.GetValues(typeof(SmjerStudija)))
                    {
                        if (ViewBag.SmjerStudija == smjer.ToString())
                        {
                            <option value="@smjer" selected>@smjer</option>
                        }
                        else
                        {
                            <option value="@smjer">@smjer</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="control-label">Predmet</label>
                <select name="predmetId" id="predmetId" class="form-select">
                    <option value="">Svi predmeti</option>

                    @foreach (var predmet in ViewBag.Predmeti)
                    {
                        var selected = ViewBag.PredmetId != null && (int)ViewBag.PredmetId == predmet.IdPredmeta;

                        if (selected)
                        {
                            <option value="@predmet.IdPredmeta" selected>@predmet.Naziv</option>
                        }
                        else
                        {
                            <option value="@predmet.IdPredmeta">@predmet.Naziv</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="control-label">Status</label>
                <select name="statusSesije" class="form-select" asp-items="ViewBag.StatusiSesije">
                    <option value="">Svi statusi</option>
                </select>
            </div>

            <div class="form-group">
                <label class="control-label">Sortiranje</label>
                <select name="sortiranje" class="form-select" asp-items="ViewBag.Sortiranja"></select>
            </div>

            <div class="form-group filter-checkbox">
                <label class="control-label">Dostupnost</label>
                <div class="form-check pretty-check">
                    <input class="form-check-input"
                           type="checkbox"
                           name="samoSlobodnaMjesta"
                           value="true"
                           id="samoSlobodnaMjesta"
                           checked="@samoSlobodnaMjesta" />
                    <label class="form-check-label" for="samoSlobodnaMjesta">
                        Samo sesije sa slobodnim mjestima
                    </label>
                </div>
            </div>
        </div>

        <div class="filter-actions">
            <button type="submit" class="btn btn-primary-sb">Primijeni filtere</button>
            <a asp-controller="SesijaUcenja" asp-action="Index" class="btn btn-outline-sb">Poništi sve filtere</a>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Nema pronađenih sesija</h3>
        <p>Trenutno nema sesija koje odgovaraju odabranim filterima.</p>
    </div>
}
else
{
    <div class="session-grid">
        @foreach (var item in Model)
        {
            var ukupnoPopunjeno = item.MaksimalanBrojUcesnika - item.BrojSlobodnihMjesta;
            var datum = item.DatumVrijeme.ToLocalTime().ToString("dd.MM.yyyy.");
            var vrijeme = item.DatumVrijeme.ToLocalTime().ToString("HH:mm");
            var statusClass = item.StatusSesije.ToString() == "Aktivna" ? "status-active" : "status-muted";

            <div class="session-card">
                <div class="session-card-top">
                    <span class="session-subject">@item.Predmet?.Naziv</span>
                    <span class="session-status @statusClass">@item.StatusSesije</span>
                </div>

                <h2>@item.Naziv</h2>

                <div class="session-meta">
                    <div>
                        <span>Datum</span>
                        <strong>@datum</strong>
                    </div>

                    <div>
                        <span>Vrijeme</span>
                        <strong>@vrijeme</strong>
                    </div>

                    <div>
                        <span>Mjesta</span>
                        <strong>@ukupnoPopunjeno/@item.MaksimalanBrojUcesnika</strong>
                    </div>
                </div>

                <div class="session-extra">
                    <span>Lokacija: <strong>@item.Lokacija?.Naziv</strong></span>
                    <span>Organizator: <strong>@item.Kreator?.Ime</strong></span>
                </div>

                <div class="session-actions">
                    <a asp-action="Details" asp-route-id="@item.IdSesije" class="btn btn-outline-sb">
                        Detalji / prijava
                    </a>

                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.IdSesije" class="btn btn-secondary">
                            Uredi
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.IdSesije" class="btn btn-danger">
                            Obriši
                        </a>
                    }
                </div>
            </div>
        }
    </div>
}