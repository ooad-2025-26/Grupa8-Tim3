@model StudyBuddyApp.Models.SesijaUcenja

@{
    ViewData["Title"] = "Brisanje sesije";
}

<div class="form-page">

    <div class="page-title-row">
        <a asp-action="Index"
               class="icon-back-btn"
               title="Nazad na sesije"
               aria-label="Nazad na sesije">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <h1>Brisanje sesije</h1>
            <p>Provjeri podatke prije trajnog brisanja sesije.</p>
        </div>
    </div>

    <div class="form-card">
        <div class="alert alert-warning">
            Da li sigurno želiš obrisati ovu sesiju? Brisanjem sesije brišu se i povezane prijave i evidencije prisustva.
        </div>

        <dl class="row details-list">
            <dt class="col-sm-4">Naziv</dt>
            <dd class="col-sm-8">@Model.Naziv</dd>

            <dt class="col-sm-4">Opis</dt>
            <dd class="col-sm-8">@Model.Opis</dd>

            <dt class="col-sm-4">Datum i vrijeme</dt>
            <dd class="col-sm-8">@Model.DatumVrijeme.ToString("dd.MM.yyyy. HH:mm")</dd>

            <dt class="col-sm-4">Trajanje</dt>
            <dd class="col-sm-8">@Model.Trajanje min</dd>

            <dt class="col-sm-4">Lokacija</dt>
            <dd class="col-sm-8">@(Model.Lokacija?.Naziv ?? "Nije definisana")</dd>

            <dt class="col-sm-4">Predmet</dt>
            <dd class="col-sm-8">@(Model.Predmet?.Naziv ?? "Nije definisan")</dd>

            <dt class="col-sm-4">Kreator</dt>
            <dd class="col-sm-8">
                @(Model.Kreator != null ? $"{Model.Kreator.Ime} {Model.Kreator.Prezime}" : "Nije definisan")
            </dd>

            <dt class="col-sm-4">Kapacitet</dt>
            <dd class="col-sm-8">@Model.MaksimalanBrojUcesnika</dd>

            <dt class="col-sm-4">Slobodna mjesta</dt>
            <dd class="col-sm-8">@Model.BrojSlobodnihMjesta</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.StatusSesije</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdSesije" />

            <div class="form-actions">
                <button type="submit" class="btn btn-danger btn-action-equal">
                    Obriši sesiju
                </button>

                <a asp-action="Index" class="btn btn-outline-sb btn-action-equal">
                    Odustani
                </a>
            </div>
        </form>
    </div>
</div>