@model StudyBuddyApp.Models.SesijaUcenja
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Detalji sesije";
    bool vecPrijavljen = ViewBag.VecPrijavljen == true;
    int? idPrijave = ViewBag.IdPrijave as int?;

    var datum = Model.DatumVrijeme.ToLocalTime().ToString("dd.MM.yyyy.");
    var vrijeme = Model.DatumVrijeme.ToLocalTime().ToString("HH:mm");
    var popunjeno = Model.MaksimalanBrojUcesnika - Model.BrojSlobodnihMjesta;
    var statusClass = Model.StatusSesije == StatusSesije.Aktivna ? "status-active" : "status-muted";
}

<div class="page-header">
    <div class="page-title-row">
        <a asp-controller="Home"
               asp-action="Index"
               class="icon-back-btn"
               title="Nazad na početnu"
               aria-label="Nazad na početnu">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <h1>Detalji sesije</h1>
        </div>
    </div>
</div>

@if (TempData["Poruka"] != null)
{
    <div class="alert alert-success">
        @TempData["Poruka"]
    </div>
}

@if (TempData["Greska"] != null)
{
    <div class="alert alert-danger">
        @TempData["Greska"]
    </div>
}

<div class="details-card">
    <div class="details-top">
        <div>
            <span class="session-subject">@Model.Predmet?.Naziv</span>
            <h2>@Model.Naziv</h2>
        </div>

        <span class="session-status @statusClass">
            @Model.StatusSesije
        </span>
    </div>

    <div class="details-meta-grid">
        <div class="details-meta-item">
            <span>Datum</span>
            <strong>@datum</strong>
        </div>

        <div class="details-meta-item">
            <span>Vrijeme</span>
            <strong>@vrijeme</strong>
        </div>

        <div class="details-meta-item">
            <span>Trajanje</span>
            <strong>@Model.Trajanje min</strong>
        </div>

        <div class="details-meta-item">
            <span>Kapacitet</span>
            <strong>@popunjeno/@Model.MaksimalanBrojUcesnika</strong>
        </div>

        <div class="details-meta-item">
            <span>Slobodna mjesta</span>
            <strong>@Model.BrojSlobodnihMjesta</strong>
        </div>

        <div class="details-meta-item">
            <span>Lokacija</span>
            <strong>@Model.Lokacija?.Naziv</strong>
        </div>
    </div>

    <div class="details-info">
        <div>
            <span>Organizator</span>
            <strong>@Model.Kreator?.Ime</strong>
        </div>

        <div>
            <span>Predmet</span>
            <strong>@Model.Predmet?.Naziv</strong>
        </div>
    </div>

    <div class="details-description">
        <h3>Opis sesije</h3>
        <p>@Model.Opis</p>
    </div>

    <div class="details-actions">
        @if (User.IsInRole("Student"))
        {
            if (vecPrijavljen && idPrijave.HasValue)
            {
                <form asp-action="CancelJoin" asp-route-id="@idPrijave.Value" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-soft-warning btn-action-equal">
                        Otkaži prijavu
                    </button>
                </form>
            }
            else if (Model.StatusSesije == StatusSesije.Aktivna && Model.BrojSlobodnihMjesta > 0)
            {
                <form asp-action="Join" asp-route-id="@Model.IdSesije" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-join btn-action-equal">
                        Prijavi se
                    </button>
                </form>
            }
            else if (Model.StatusSesije != StatusSesije.Aktivna)
            {
                <span class="details-note">Prijava nije moguća jer sesija nije aktivna.</span>
            }
            else if (Model.BrojSlobodnihMjesta <= 0)
            {
                <span class="details-note">Sesija je popunjena.</span>
            }
        }

        @if (User.IsInRole("Moderator"))
        {
            <a asp-action="EditStatus"
                   asp-route-id="@Model.IdSesije"
                   class="btn btn-primary-sb btn-action-equal">
                Uredi status
            </a>
        }

        @if (User.IsInRole("Administrator"))
        {
            <a asp-action="Edit" asp-route-id="@Model.IdSesije" class="btn btn-primary-sb btn-action-equal">
                Uredi
            </a>
        }

        <a asp-action="Index" class="btn btn-outline-sb btn-action-equal">
            Nazad na sesije
        </a>
    </div>
</div>