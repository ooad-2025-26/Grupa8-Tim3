@model StudyBuddyApp.Models.SesijaUcenja
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Detalji sesije";
    bool vecPrijavljen = ViewBag.VecPrijavljen == true;
    int? idPrijave = ViewBag.IdPrijave as int?;
}

<h1>Detalji sesije</h1>

@if (TempData["Poruka"] != null)
{
    <div class="alert alert-success">
        @TempData["Poruka"]
    </div>
}

@if (TempData["Greska"] != null)
{
    <div class="alert alert-danger">
        @TempData["Greska"]
    </div>
}

<div>
    <h4>Sesija učenja</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Naziv)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Naziv)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Opis)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Opis)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DatumVrijeme)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DatumVrijeme)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Trajanje)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Trajanje)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Lokacija)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Lokacija!.Naziv)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Predmet)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Predmet!.Naziv)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Kreator)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Kreator!.Ime)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MaksimalanBrojUcesnika)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MaksimalanBrojUcesnika)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BrojSlobodnihMjesta)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.BrojSlobodnihMjesta)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.StatusSesije)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.StatusSesije)
        </dd>
    </dl>
</div>

<div class="mb-3">
    @if (User.IsInRole("Student"))
    {
        if (vecPrijavljen && idPrijave.HasValue)
        {
            <form asp-action="CancelJoin" asp-route-id="@idPrijave.Value" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning">Otkaži prijavu</button>
            </form>
        }
        else if (Model.StatusSesije == StatusSesije.Aktivna && Model.BrojSlobodnihMjesta > 0)
        {
            <form asp-action="Join" asp-route-id="@Model.IdSesije" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success">Prijavi se</button>
            </form>
        }
    }

    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Edit" asp-route-id="@Model.IdSesije" class="btn btn-primary">Edit</a>
    }

    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>