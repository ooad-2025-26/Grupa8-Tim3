@model StudyBuddyApp.Models.Lokacija
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Kreiranje lokacije";
}

<div class="page-header">
    <div>
        <h1>Kreiranje lokacije</h1>
        <p>Dodaj fizičku ili online lokaciju koja će se koristiti za sesije učenja.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Naziv" class="control-label">Naziv lokacije</label>
                <input asp-for="Naziv" class="form-control" placeholder="Npr. Čitaonica STELEKS" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TipLokacije" class="control-label">Tip lokacije</label>
                <select asp-for="TipLokacije" class="form-select" asp-items="Html.GetEnumSelectList<TipLokacije>()" id="tipLokacijeSelect">
                    <option value="">-- Odaberite tip lokacije --</option>
                </select>
                <span asp-validation-for="TipLokacije" class="text-danger"></span>
            </div>

            <div class="form-group form-full" id="adresaPolje" style="display:none;">
                <label asp-for="Adresa" class="control-label">Adresa</label>
                <input asp-for="Adresa" class="form-control" placeholder="Npr. Zmaja od Bosne bb" />
                <span asp-validation-for="Adresa" class="text-danger"></span>
            </div>

            <div class="form-group form-full" id="linkPolje" style="display:none;">
                <label asp-for="Link" class="control-label">Link</label>
                <input asp-for="Link" class="form-control" placeholder="Npr. https://teams.microsoft.com/..." />
                <span asp-validation-for="Link" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary-sb">Sačuvaj</button>
            <a asp-action="Index" class="btn btn-outline-sb">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function prikaziPoljaZaTipLokacije() {
            const select = document.getElementById("tipLokacijeSelect");
            const odabraniTekst = select.options[select.selectedIndex]?.text?.toLowerCase() || "";

            const adresaPolje = document.getElementById("adresaPolje");
            const linkPolje = document.getElementById("linkPolje");

            adresaPolje.style.display = "none";
            linkPolje.style.display = "none";

            if (odabraniTekst.includes("online")) {
                linkPolje.style.display = "block";
            } else if (odabraniTekst.includes("fiz")) {
                adresaPolje.style.display = "block";
            }
        }

        document.getElementById("tipLokacijeSelect").addEventListener("change", prikaziPoljaZaTipLokacije);
        prikaziPoljaZaTipLokacije();
    </script>
}