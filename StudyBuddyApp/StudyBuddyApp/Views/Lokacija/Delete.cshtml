@model StudyBuddyApp.Models.Lokacija

@{
    ViewData["Title"] = "Brisanje lokacije";
}

<div class="page-header">
    <div>
        <h1>Brisanje lokacije</h1>
        <p>Provjeri podatke prije brisanja lokacije iz sistema.</p>
    </div>
</div>

<div class="details-card delete-card">
    <div class="session-card-top">
        <span class="session-subject">@Model.TipLokacije</span>
    </div>

    <h2>@Model.Naziv</h2>

    <div class="alert alert-danger">
        Da li ste sigurni da želite obrisati ovu lokaciju?
    </div>

    <div class="details-info">
        <div>
            <span>Tip lokacije</span>
            <strong>@Model.TipLokacije</strong>
        </div>

        <div>
            <span>Adresa</span>
            <strong>
                @(string.IsNullOrWhiteSpace(Model.Adresa) ? "Nije unesena" : Model.Adresa)
            </strong>
        </div>

        <div>
            <span>Link</span>
            @if (!string.IsNullOrWhiteSpace(Model.Link))
            {
                <strong>
                    <a href="@Model.Link" target="_blank" rel="noopener noreferrer">
                        Otvori link
                    </a>
                </strong>
            }
            else
            {
                <strong>Nije unesen</strong>
            }
        </div>
    </div>

    <form asp-action="Delete" method="post" class="details-actions">
        <input type="hidden" asp-for="IdLokacije" />

        <button type="submit" class="btn btn-danger">
            Obriši lokaciju
        </button>

        <a asp-action="Index" class="btn btn-outline-sb">
            Odustani
        </a>
    </form>
</div>