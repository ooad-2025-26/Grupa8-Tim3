@model IEnumerable<StudyBuddyApp.Models.Lokacija>

@{
    ViewData["Title"] = "Lokacije";
}

<div class="page-header">
    <div>
        <h1>Lokacije</h1>
        <p>Pregled fizičkih i online lokacija koje se koriste za sesije učenja.</p>
    </div>

    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary-sb">Dodaj lokaciju</a>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Nema lokacija</h3>
        <p>Trenutno nema dodanih lokacija u sistemu.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Naziv</th>
                    <th>Tip lokacije</th>
                    <th>Adresa</th>
                    <th>Link</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var tipClass = item.TipLokacije.ToString() == "Online" ? "status-active" : "status-muted";
                    var adresa = string.IsNullOrWhiteSpace(item.Adresa) ? "-" : item.Adresa;
                    var link = string.IsNullOrWhiteSpace(item.Link) ? "-" : item.Link;

                    <tr>
                        <td>@item.Naziv</td>
                        <td>
                            <span class="session-status @tipClass">
                                @item.TipLokacije
                            </span>
                        </td>
                        <td>@adresa</td>
                        <td>
                            @if (link == "-")
                            {
                                <span>-</span>
                            }
                            else
                            {
                                <a href="@item.Link" target="_blank">Otvori link</a>
                            }
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.IdLokacije" class="btn btn-outline-sb btn-sm">
                                    Detalji
                                </a>

                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IdLokacije" class="btn btn-secondary btn-sm">
                                        Uredi
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.IdLokacije" class="btn btn-danger btn-sm">
                                        Obriši
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}