@model StudyBuddyApp.Models.Predmet

@{
    ViewData["Title"] = "Brisanje predmeta";
    var statusClass = Model.StatusPredmeta.ToString() == "Aktivan" ? "status-active" : "status-muted";
}

<div class="page-header">
    <div>
        <h1>Brisanje predmeta</h1>
        <p>Provjeri podatke prije brisanja predmeta iz sistema.</p>
    </div>
</div>

<div class="details-card delete-card">
    <div class="session-card-top">
        <span class="session-subject">@Model.Oznaka</span>
        <span class="session-status @statusClass">@Model.StatusPredmeta</span>
    </div>

    <h2>@Model.Naziv</h2>

    <div class="alert alert-danger">
        Da li ste sigurni da želite obrisati ovaj predmet?
    </div>

    <div class="details-info">
        <div>
            <span>Godina studija</span>
            <strong>@Model.GodinaStudija</strong>
        </div>

        <div>
            <span>Smjer studija</span>
            <strong>@Model.SmjerStudija</strong>
        </div>

        <div>
            <span>Oznaka</span>
            <strong>@Model.Oznaka</strong>
        </div>

        <div>
            <span>Status</span>
            <strong>@Model.StatusPredmeta</strong>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="details-actions">
        <input type="hidden" asp-for="IdPredmeta" />

        <button type="submit" class="btn btn-danger">
            Obriši predmet
        </button>

        <a asp-action="Index" class="btn btn-outline-sb">
            Odustani
        </a>
    </form>
</div>