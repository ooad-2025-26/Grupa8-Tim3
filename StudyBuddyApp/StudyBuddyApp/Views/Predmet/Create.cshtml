@model StudyBuddyApp.Models.Predmet
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Kreiranje predmeta";
}

<div class="page-header">
    <div>
        <h1>Kreiranje predmeta</h1>
        <p>Dodaj predmet koji će se koristiti pri organizaciji sesija učenja.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Naziv" class="control-label">Naziv predmeta</label>
                <input asp-for="Naziv" class="form-control" placeholder="Npr. Objektno orijentisana analiza i dizajn" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Oznaka" class="control-label">Oznaka</label>
                <input asp-for="Oznaka" class="form-control" placeholder="Npr. OOAD" />
                <span asp-validation-for="Oznaka" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="GodinaStudija" class="control-label">Godina studija</label>
                <select asp-for="GodinaStudija" class="form-select" asp-items="Html.GetEnumSelectList<GodinaStudija>()"></select>
                <span asp-validation-for="GodinaStudija" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SmjerStudija" class="control-label">Smjer studija</label>
                <select asp-for="SmjerStudija" class="form-select" asp-items="Html.GetEnumSelectList<SmjerStudija>()"></select>
                <span asp-validation-for="SmjerStudija" class="text-danger"></span>
            </div>

            <div class="form-group form-full">
                <label asp-for="StatusPredmeta" class="control-label">Status predmeta</label>
                <select asp-for="StatusPredmeta" class="form-select" asp-items="Html.GetEnumSelectList<StatusPredmeta>()"></select>
                <span asp-validation-for="StatusPredmeta" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary-sb">Sačuvaj</button>
            <a asp-action="Index" class="btn btn-outline-sb">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}