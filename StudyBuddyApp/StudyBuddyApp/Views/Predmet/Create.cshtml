@model StudyBuddyApp.Models.Predmet
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Kreiranje predmeta";
}

<h1>Kreiranje predmeta</h1>

<h4>Predmet</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Naziv" class="control-label"></label>
                <input asp-for="Naziv" class="form-control" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Opis" class="control-label"></label>
                <textarea asp-for="Opis" class="form-control"></textarea>
                <span asp-validation-for="Opis" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Oznaka" class="control-label"></label>
                <input asp-for="Oznaka" class="form-control" />
                <span asp-validation-for="Oznaka" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StatusPredmeta" class="control-label"></label>
                <select asp-for="StatusPredmeta" class="form-control" asp-items="Html.GetEnumSelectList<StatusPredmeta>()"></select>
                <span asp-validation-for="StatusPredmeta" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}