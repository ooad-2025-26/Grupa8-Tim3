@model IEnumerable<StudyBuddyApp.Models.Predmet>

@{
    ViewData["Title"] = "Predmeti";
}

<h1>Predmeti</h1>

@if (User.IsInRole("Administrator"))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Naziv)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Opis)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Oznaka)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StatusPredmeta)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Naziv)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Opis)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Oznaka)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.StatusPredmeta)
                </td>
                <td>
                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.IdPredmeta">Edit</a>
                        <span>|</span>
                    }

                    <a asp-action="Details" asp-route-id="@item.IdPredmeta">Details</a>

                    @if (User.IsInRole("Administrator"))
                    {
                        <span>|</span>
                        <a asp-action="Delete" asp-route-id="@item.IdPredmeta">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>