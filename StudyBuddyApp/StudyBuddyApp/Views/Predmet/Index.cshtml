@model IEnumerable<StudyBuddyApp.Models.Predmet>
@using StudyBuddyApp.Models

@{
    ViewData["Title"] = "Predmeti";
}

<div class="page-header">
    <div class="page-title-row">
        <a asp-controller="Home"
               asp-action="Index"
               class="icon-back-btn"
               title="Nazad na početnu"
               aria-label="Nazad na početnu">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <div>
                <h1>Predmeti</h1>
                <p>Pregled predmeta koji se koriste pri kreiranju sesija učenja.</p>
            </div>
        </div>
    </div>
    
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary-sb">Dodaj predmet</a>
    }
</div>

<div class="session-filter-card">
    <form asp-controller="Predmet" asp-action="Index" method="get">
        <div class="session-filter-grid">
            <div class="form-group filter-search">
                <label class="control-label">Pretraga</label>
                <input type="text"
                       name="pretraga"
                       value="@ViewBag.Pretraga"
                       class="form-control"
                       placeholder="Pretraži naziv, oznaku ili opis predmeta..." />
            </div>

            <div class="form-group">
                <label class="control-label">Godina studija</label>
                <select name="godinaStudija" class="form-select">
                    <option value="">Sve godine</option>
                    @foreach (GodinaStudija godina in Enum.GetValues(typeof(GodinaStudija)))
                    {
                        if (ViewBag.GodinaStudija == godina.ToString())
                        {
                            <option value="@godina" selected>@godina</option>
                        }
                        else
                        {
                            <option value="@godina">@godina</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="control-label">Smjer studija</label>
                <select name="smjerStudija" class="form-select">
                    <option value="">Svi smjerovi</option>
                    @foreach (SmjerStudija smjer in Enum.GetValues(typeof(SmjerStudija)))
                    {
                        if (ViewBag.SmjerStudija == smjer.ToString())
                        {
                            <option value="@smjer" selected>@smjer</option>
                        }
                        else
                        {
                            <option value="@smjer">@smjer</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="control-label">Status</label>
                <select name="statusPredmeta" class="form-select">
                    <option value="">Svi statusi</option>
                    @foreach (StatusPredmeta status in Enum.GetValues(typeof(StatusPredmeta)))
                    {
                        if (ViewBag.StatusPredmeta == status.ToString())
                        {
                            <option value="@status" selected>@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="filter-actions">
            <button type="submit" class="btn btn-primary-sb">Primijeni filtere</button>
            <a asp-controller="Predmet" asp-action="Index" class="btn btn-outline-sb">Poništi sve filtere</a>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Nema predmeta</h3>
        <p>Trenutno nema dodanih predmeta u sistemu.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Naziv</th>
                    <th>Oznaka</th>
                    <th>Godina</th>
                    <th>Smjer</th>
                    <th>Status</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.StatusPredmeta.ToString() == "Aktivan" ? "status-active" : "status-muted";

                    <tr>
                        <td>@item.Naziv</td>

                        <td>
                            <span class="session-subject">@item.Oznaka</span>
                        </td>

                        <td>@item.GodinaStudija</td>

                        <td>@item.SmjerStudija</td>

                        <td>
                            <span class="session-status @statusClass">
                                @item.StatusPredmeta
                            </span>
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.IdPredmeta" class="btn btn-outline-sb btn-sm">
                                    Detalji
                                </a>

                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IdPredmeta" class="btn btn-secondary btn-sm">
                                        Uredi
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.IdPredmeta" class="btn btn-danger btn-sm">
                                        Obriši
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}