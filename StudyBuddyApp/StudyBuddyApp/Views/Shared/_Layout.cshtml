<!DOCTYPE html>
<html lang="bs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyBuddyApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudyBuddyApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">StudyBuddy</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Prikaži navigaciju">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div id="mainNavbar" class="navbar-collapse collapse justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Početna</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="SesijaUcenja" asp-action="Index">Sesije</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="PrijavaNaSesiju" asp-action="Index">Prijave</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Prisustvo" asp-action="Index">Prisustvo</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Statistika" asp-action="Index">Statistika</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-with-badge" asp-controller="Obavjestenje" asp-action="Index">
                                        Obavještenja
                                        @await Component.InvokeAsync("UnreadNotifications")
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Moderator"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="SesijaUcenja" asp-action="Index">Sesije</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Prisustvo" asp-action="Index">Prisustvo</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Statistika" asp-action="Index">Statistika</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-with-badge" asp-controller="Obavjestenje" asp-action="Index">
                                        Obavještenja
                                        @await Component.InvokeAsync("UnreadNotifications")
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Administrator"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="SesijaUcenja" asp-action="Index">Sesije</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="PrijavaNaSesiju" asp-action="Index">Prijave</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Prisustvo" asp-action="Index">Prisustvo</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Statistika" asp-action="Index">Statistika</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-with-badge" asp-controller="Obavjestenje" asp-action="Index">
                                        Obavještenja
                                        @await Component.InvokeAsync("UnreadNotifications")
                                    </a>
                                </li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button"
                                           data-bs-toggle="dropdown" aria-expanded="false">
                                        Administracija
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Korisnik" asp-action="Index">Korisnici</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Predmet" asp-action="Index">Predmeti</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Lokacija" asp-action="Index">Lokacije</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Uloga" asp-action="Index">Uloge</a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privatnost</a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; 2026 - StudyBuddyApp
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>