@model IEnumerable<StudyBuddyApp.Models.Korisnik>

@{
    ViewData["Title"] = "Korisnici";
}

<div class="page-header">
    <div class="page-title-row">
        <a asp-controller="Home"
               asp-action="Index"
               class="icon-back-btn"
               title="Nazad na početnu"
               aria-label="Nazad na početnu">
            <span class="back-icon">‹</span>
        </a>

        <div class="page-title-text">
            <div>
                <h1>Korisnici</h1>
                <p>Pregled korisnika, njihovih uloga i statusa naloga u sistemu.</p>
            </div>
        </div>
    </div>

    <a asp-action="Create" class="btn btn-primary-sb">Dodaj korisnika</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Nema korisnika</h3>
        <p>Trenutno nema korisnika za prikaz.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Ime</th>
                    <th>Prezime</th>
                    <th>Email</th>
                    <th>Uloga</th>
                    <th>Status naloga</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.StatusNaloga.ToString() == "Aktivan" ? "status-active" : "status-muted";

                    <tr>
                        <td>@item.Ime</td>
                        <td>@item.Prezime</td>
                        <td>@item.Email</td>
                        <td>
                            <span class="session-subject">
                                @item.Uloga
                            </span>
                        </td>
                        <td>
                            <span class="session-status @statusClass">
                                @item.StatusNaloga
                            </span>
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-sb btn-sm">
                                    Detalji
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                                    Uredi
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                    Obriši
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}