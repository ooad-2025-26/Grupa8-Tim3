@model StudyBuddyApp.Models.Korisnik

@{
    ViewData["Title"] = "Brisanje korisnika";
    var punoIme = $"{Model.Ime} {Model.Prezime}";
    var statusClass = Model.StatusNaloga.ToString() == "Aktivan" ? "status-active" : "status-muted";
}

<div class="page-header">
    <div>
        <h1>Brisanje korisnika</h1>
        <p>Provjeri podatke prije brisanja korisničkog naloga.</p>
    </div>
</div>

<div class="details-card delete-card">
    <div class="session-card-top">
        <span class="session-subject">@Model.Uloga</span>
        <span class="session-status @statusClass">@Model.StatusNaloga</span>
    </div>

    <h2>@punoIme</h2>

    <div class="alert alert-danger">
        Da li ste sigurni da želite obrisati ovog korisnika?
    </div>

    <div class="details-info">
        <div>
            <span>Ime</span>
            <strong>@Model.Ime</strong>
        </div>

        <div>
            <span>Prezime</span>
            <strong>@Model.Prezime</strong>
        </div>

        <div>
            <span>Email</span>
            <strong>@Model.Email</strong>
        </div>

        <div>
            <span>Uloga</span>
            <strong>@Model.Uloga</strong>
        </div>

        <div>
            <span>Status naloga</span>
            <strong>@Model.StatusNaloga</strong>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="details-actions">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">
            Obriši korisnika
        </button>

        <a asp-action="Index" class="btn btn-outline-sb">
            Odustani
        </a>
    </form>
</div>