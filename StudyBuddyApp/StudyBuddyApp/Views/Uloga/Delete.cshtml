@model StudyBuddyApp.Models.Uloga

@{
    ViewData["Title"] = "Brisanje uloge";
}

<div class="page-header">
    <div>
        <h1>Brisanje uloge</h1>
        <p>Provjeri podatke prije brisanja korisničke uloge.</p>
    </div>
</div>

<div class="details-card delete-card">
    <div class="session-card-top">
        <span class="session-subject">Uloga</span>
    </div>

    <h2>@Model.Naziv</h2>

    <div class="alert alert-danger">
        Da li ste sigurni da želite obrisati ovu ulogu?
    </div>

    <div class="details-info">
        <div>
            <span>Naziv</span>
            <strong>@Model.Naziv</strong>
        </div>

        <div>
            <span>Opis</span>
            <strong>
                @(string.IsNullOrWhiteSpace(Model.Opis) ? "Nije unesen" : Model.Opis)
            </strong>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="details-actions">
        <input type="hidden" asp-for="IdUloge" />

        <button type="submit" class="btn btn-danger">
            Obriši ulogu
        </button>

        <a asp-action="Index" class="btn btn-outline-sb">
            Odustani
        </a>
    </form>
</div>