@model StudyBuddyApp.Models.Uloga

@{
    ViewData["Title"] = "Dodavanje uloge";
}

<div class="page-header">
    <div>
        <h1>Dodavanje uloge</h1>
        <p>Dodaj novu ulogu koja opisuje prava pristupa korisnika u sistemu.</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Naziv" class="control-label">Naziv</label>
                <input asp-for="Naziv" class="form-control" placeholder="Npr. Student" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>

            <div class="form-group form-full">
                <label asp-for="Opis" class="control-label">Opis</label>
                <textarea asp-for="Opis" class="form-control" rows="4" placeholder="Ukratko opiši prava i namjenu ove uloge."></textarea>
                <span asp-validation-for="Opis" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary-sb">
                Sačuvaj
            </button>

            <a asp-action="Index" class="btn btn-outline-sb">
                Odustani
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}